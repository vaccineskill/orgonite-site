---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact | OrgoniteGuide" description="Contact OrgoniteGuide with questions, corrections, or suggestions.">
  <div class="max-w-2xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-extrabold text-white mb-4 tracking-tight">Contact</h1>
    <p class="text-[#71717a] mb-8">Have a question, found an error, or want to suggest a resource? Get in touch.</p>
    <a href="mailto:hello@orgoniteguide.com" class="inline-block bg-[#a78bfa] text-[#09090b] font-semibold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity">
      hello@orgoniteguide.com
    </a>
  </div>
</BaseLayout>
