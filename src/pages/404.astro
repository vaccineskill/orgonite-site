---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | OrgoniteGuide" description="This page could not be found.">
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <div class="text-6xl mb-6">⚡</div>
    <h1 class="text-4xl font-extrabold text-white mb-4 tracking-tight">404 — Page Not Found</h1>
    <p class="text-[#71717a] mb-8">The orgone has dispersed. This page doesn't exist.</p>
    <a href="/" class="inline-block bg-[#a78bfa] text-[#09090b] font-semibold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity">
      Back to Homepage
    </a>
  </div>
</BaseLayout>
