---
import BaseLayout from './BaseLayout.astro';
import { CATEGORIES } from '../data/categories';

interface WikiImage {
  src: string;
  alt: string;
  artist: string;
  license: string;
  licenseUrl: string;
  commonsUrl: string;
}

interface FaqItem {
  q: string;
  a: string;
}

// Load per-article FAQs
let allFaqs: Record<string, FaqItem[]> = {};
try {
  const mod = await import('../data/articleFaqs.json', { assert: { type: 'json' } });
  allFaqs = mod.default as Record<string, FaqItem[]>;
} catch { /* fine */ }

interface Props {
  title: string;
  description: string;
  category: string;
  readTime: number;
  source?: string;
  pdfFile?: string;
  slug: string;
  headings: Array<{depth: number; slug: string; text: string}>;
  relatedArticles: Array<{slug: string; data: {title: string; category: string; slug: string}}>;
  nextArticle?: {slug: string; data: {title: string; slug: string}};
  canonical?: string;
  articleImages?: string[];
  wikiImages?: WikiImage[];
}
const { title, description, category, readTime, source, pdfFile, slug, headings, relatedArticles, nextArticle, canonical, articleImages, wikiImages } = Astro.props;
const cat = CATEGORIES[category as keyof typeof CATEGORIES];
const catName = cat?.name || category;
const catSlug = cat?.slug || category;

// FAQ data for this article
const articleFaqs: FaqItem[] = (allFaqs[slug] || []).filter(f => f && f.q && f.a);

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "name": title,
  "description": description,
  "url": `https://orgoniteguide.com/${catSlug}/${slug}/`,
  "publisher": { "@type": "Organization", "name": "OrgoniteGuide" },
  "isPartOf": { "@type": "WebSite", "name": "OrgoniteGuide", "url": "https://orgoniteguide.com" }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://orgoniteguide.com/" },
    { "@type": "ListItem", "position": 2, "name": catName, "item": `https://orgoniteguide.com/${catSlug}/` },
    { "@type": "ListItem", "position": 3, "name": title }
  ]
});
---

<BaseLayout title={`${title} | OrgoniteGuide`} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
    {articleFaqs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": articleFaqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a }
        }))
      })} />
    )}
  </Fragment>

  <!-- Leaderboard ad -->
  <div class="max-w-6xl mx-auto px-4 mt-4">
    <div class="ad-leaderboard h-[90px] bg-[#0d0d10] border border-dashed border-[#2a2a35] rounded-lg flex items-center justify-center text-xs text-[#3f3f50] tracking-widest uppercase">
      Advertisement
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-xs text-[#52525b] mb-4">
      <a href="/" class="hover:text-[#a78bfa]">Home</a>
      <span class="mx-1">›</span>
      <a href={`/${catSlug}/`} class="hover:text-[#a78bfa]">{catName}</a>
      <span class="mx-1">›</span>
      <span class="text-[#71717a]">{title}</span>
    </nav>

    <div class="flex gap-8">
      <!-- Main article -->
      <article class="flex-1 min-w-0">
        <!-- Tags -->
        <div class="flex gap-2 flex-wrap mb-4">
          <span class="bg-[#18181b] border border-[#27272a] text-[#a78bfa] text-xs px-3 py-0.5 rounded-full">{catName}</span>
          <span class="bg-[#18181b] border border-[#27272a] text-[#71717a] text-xs px-3 py-0.5 rounded-full">⏱ {readTime} min read</span>
        </div>

        <!-- Mobile TOC -->
        {headings.filter(h => h.depth <= 2).length > 2 && (
          <details class="lg:hidden mb-6 bg-[#111113] border border-[#1e1e22] rounded-xl p-4">
            <summary class="text-xs font-semibold tracking-widest uppercase text-[#52525b] cursor-pointer">Table of Contents</summary>
            <ul class="mt-3 space-y-2">
              {headings.filter(h => h.depth <= 2).map(h => (
                <li>
                  <a href={`#${h.slug}`} class="text-sm text-[#71717a] hover:text-[#a78bfa]">
                    {h.depth === 2 ? '' : '  '}{h.text}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        )}

        <h1 class="text-3xl md:text-4xl font-extrabold leading-tight tracking-tight text-white mb-4">{title}</h1>

        <div class="flex items-center gap-3 text-xs text-[#52525b] mb-4 pb-4 border-b border-[#18181b]">
          <span>📚 OrgoniteGuide Research Library</span>
          <span>·</span>
          <span>⏱ {readTime} min read</span>
        </div>

        <!-- PDF Download button -->
        {pdfFile && (
          <div class="mb-6">
            <a href={`/pdfs/${encodeURIComponent(pdfFile)}`}
               download
               class="pdf-download-btn">
              📄 Download Original PDF
            </a>
          </div>
        )}

        <!-- Article body -->
        <div class="prose-content">
          <slot />
        </div>

        <!-- Photos from original document -->
        {articleImages && articleImages.length > 0 && (
          <div class="mt-10 pt-6 border-t border-[#18181b]">
            <h3 class="text-xs font-semibold tracking-widest uppercase text-[#52525b] mb-4">Photos from Original Document</h3>
            <div class="image-grid">
              {articleImages.map((imgPath, i) => (
                <a href={`/${imgPath}`} target="_blank" rel="noopener" class="image-grid-item">
                  <img src={`/${imgPath}`} alt={`Document image ${i + 1}`} loading="lazy" />
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Wikimedia Commons images with attribution -->
        {wikiImages && wikiImages.length > 0 && (
          <div class="wiki-images-section mt-10 pt-6 border-t border-[#18181b]">
            <h3 class="wiki-images-heading">Related Images</h3>
            <div class="wiki-image-grid">
              {wikiImages.map((img) => (
                <figure class="wiki-figure">
                  <a href={img.commonsUrl} target="_blank" rel="noopener noreferrer">
                    <img
                      src={img.src}
                      alt={img.alt || title}
                      loading="lazy"
                      class="wiki-img"
                    />
                  </a>
                  <figcaption class="wiki-caption">
                    {img.alt && <span class="wiki-desc">{img.alt}</span>}
                    <span class="wiki-credit">
                      © <a href={img.commonsUrl} target="_blank" rel="noopener noreferrer">{img.artist}</a>
                      {' · '}
                      <a href={img.licenseUrl} target="_blank" rel="noopener noreferrer">{img.license}</a>
                      {' · '}
                      <a href="https://commons.wikimedia.org" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a>
                    </span>
                  </figcaption>
                </figure>
              ))}
            </div>
          </div>
        )}

        <!-- FAQ Section -->
        {articleFaqs.length > 0 && (
          <section class="mt-10 pt-6 border-t border-[#18181b]" aria-label="Frequently Asked Questions">
            <h2 class="text-lg font-bold text-white mb-4">Frequently Asked Questions</h2>
            <div class="space-y-3">
              {articleFaqs.map((faq, i) => (
                <details class="faq-item group bg-[#111113] border border-[#1e1e22] rounded-xl overflow-hidden" open={i === 0}>
                  <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer text-sm font-semibold text-[#e4e4e7] hover:text-white list-none select-none">
                    <span>{faq.q}</span>
                    <span class="faq-chevron flex-shrink-0 text-[#a78bfa] transition-transform duration-200">▾</span>
                  </summary>
                  <div class="px-5 pb-4 pt-1 text-sm text-[#a1a1aa] leading-relaxed border-t border-[#1e1e22]">
                    {faq.a}
                  </div>
                </details>
              ))}
            </div>
          </section>
        )}

        <!-- Next article -->
        {nextArticle && (
          <div class="mt-12 pt-6 border-t border-[#18181b]">
            <p class="text-xs text-[#52525b] uppercase tracking-widest mb-2">Next Article</p>
            <a href={`/${catSlug}/${nextArticle.data.slug}/`} class="flex items-center justify-between bg-[#111113] border border-[#1e1e22] hover:border-[#3f3f46] rounded-xl p-4 transition-colors group">
              <span class="text-white font-semibold group-hover:text-[#a78bfa] transition-colors">{nextArticle.data.title}</span>
              <span class="text-[#a78bfa]">→</span>
            </a>
          </div>
        )}
      </article>

      <!-- Sidebar (desktop only) -->
      <aside class="hidden lg:block w-72 flex-shrink-0">
        <div class="sticky top-20 space-y-4">
          <!-- TOC -->
          {headings.filter(h => h.depth <= 2).length > 2 && (
            <div class="bg-[#111113] border border-[#1e1e22] rounded-xl p-4">
              <h4 class="text-xs font-semibold tracking-widest uppercase text-[#52525b] mb-3">Table of Contents</h4>
              <ul class="space-y-2">
                {headings.filter(h => h.depth <= 2).map(h => (
                  <li>
                    <a href={`#${h.slug}`} class={`text-xs text-[#71717a] hover:text-[#a78bfa] transition-colors ${h.depth === 2 ? '' : 'pl-3'}`}>
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Sidebar ad 1 -->
          <div class="h-[250px] bg-[#0d0d10] border border-dashed border-[#2a2a35] rounded-xl flex items-center justify-center text-xs text-[#3f3f50] tracking-widest uppercase">
            Ad · 300×250
          </div>

          <!-- Related articles -->
          {relatedArticles.length > 0 && (
            <div class="bg-[#111113] border border-[#1e1e22] rounded-xl p-4">
              <h4 class="text-xs font-semibold tracking-widest uppercase text-[#52525b] mb-3">Related Articles</h4>
              <ul class="space-y-3">
                {relatedArticles.map(a => (
                  <li>
                    <a href={`/${a.data.category}/${a.data.slug}/`} class="text-sm text-[#a1a1aa] hover:text-[#a78bfa] transition-colors leading-snug block">
                      {a.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Sidebar ad 2 -->
          <div class="h-[250px] bg-[#0d0d10] border border-dashed border-[#2a2a35] rounded-xl flex items-center justify-center text-xs text-[#3f3f50] tracking-widest uppercase">
            Ad · 300×250
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  /* PDF download button */
  .pdf-download-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #111113;
    border: 1px solid #1e1e22;
    color: #a78bfa;
    font-size: 13px;
    padding: 8px 16px;
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .pdf-download-btn:hover {
    border-color: #a78bfa;
  }

  /* Prose content typography */
  .prose-content {
    max-width: 72ch;
    font-size: 15px;
    line-height: 1.8;
    color: #a1a1aa;
  }

  .prose-content h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #fafafa;
    margin: 2.25rem 0 0.75rem;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .prose-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #e4e4e7;
    margin: 1.75rem 0 0.5rem;
    line-height: 1.4;
  }

  .prose-content h4 {
    font-size: 1rem;
    font-weight: 600;
    color: #d4d4d8;
    margin: 1.5rem 0 0.4rem;
  }

  .prose-content p {
    margin-bottom: 1.1rem;
    font-size: 15px;
    line-height: 1.8;
  }

  .prose-content ul {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    list-style-type: disc;
  }

  .prose-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    list-style-type: decimal;
  }

  .prose-content li {
    font-size: 15px;
    line-height: 1.75;
    margin-bottom: 0.35rem;
    color: #a1a1aa;
    display: list-item;
  }

  .prose-content blockquote {
    border-left: 3px solid #a78bfa;
    padding: 0.75rem 1rem;
    background: #18181b;
    border-radius: 0 8px 8px 0;
    margin: 1.5rem 0;
  }

  .prose-content blockquote p {
    color: #d4d4d8;
    font-style: italic;
    margin: 0;
  }

  .prose-content a {
    color: #a78bfa;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose-content a:hover {
    color: #c4b5fd;
  }

  .prose-content strong {
    color: #fafafa;
    font-weight: 600;
  }

  .prose-content em {
    font-style: italic;
    color: #d4d4d8;
  }

  /* Hide stray _Source: xxx_ italic lines that weren't cleaned */
  .prose-content > p > em:only-child {
    display: none;
  }

  .prose-content code {
    background: #18181b;
    color: #a78bfa;
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .prose-content pre {
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1.25rem 0;
  }

  .prose-content pre code {
    background: none;
    padding: 0;
    font-size: 0.85em;
  }

  .prose-content hr {
    border: none;
    border-top: 1px solid #1e1e22;
    margin: 2.5rem 0;
  }

  .prose-content img {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5rem auto;
    display: block;
  }

  /* Tables */
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 14px;
  }

  .prose-content th {
    background: #18181b;
    color: #e4e4e7;
    font-weight: 600;
    padding: 0.6rem 0.75rem;
    text-align: left;
    border: 1px solid #27272a;
  }

  .prose-content td {
    padding: 0.5rem 0.75rem;
    border: 1px solid #1e1e22;
    color: #a1a1aa;
    vertical-align: top;
  }

  .prose-content tr:nth-child(even) td {
    background: #111113;
  }

  /* Ad injected by rehype */
  .ad-in-content {
    background: #0d0d10;
    border: 1px dashed #2a2a35;
    border-radius: 8px;
    height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    color: #3f3f50;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Image grid for extracted PDF images */
  .image-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  @media (max-width: 640px) {
    .image-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .image-grid-item {
    display: block;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid #1e1e22;
    transition: border-color 0.15s;
  }

  .image-grid-item:hover {
    border-color: #a78bfa;
  }

  .image-grid-item img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    margin: 0;
    border-radius: 0;
    display: block;
  }

  /* Wikimedia Commons images */
  .wiki-images-heading {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #52525b;
    margin-bottom: 1rem;
  }

  .wiki-image-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }

  .wiki-figure {
    margin: 0;
    background: #111113;
    border: 1px solid #1e1e22;
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .wiki-figure:hover {
    border-color: #3f3f46;
  }

  .wiki-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    margin: 0;
    border-radius: 0;
  }

  .wiki-caption {
    padding: 8px 10px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .wiki-desc {
    font-size: 11px;
    color: #71717a;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .wiki-credit {
    font-size: 10px;
    color: #3f3f46;
    line-height: 1.4;
  }

  .wiki-credit a {
    color: #52525b;
    text-decoration: none;
  }

  .wiki-credit a:hover {
    color: #a78bfa;
  }
</style>
